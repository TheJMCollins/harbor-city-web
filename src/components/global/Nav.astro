---
/**
 * Global sticky navigation.
 *
 * Styling hardcodes --hcc-* tokens so this nav renders the main brand
 * identity on every page — ministry [data-brand] scopes don't override it.
 * This preserves the "visual anchor home" principle from Build Brief Part 1.1.
 *
 * Sitemap per v2.0:
 *   - Our Story, Your Story, Next Steps, Groups, Dream Team, Give, Blog
 *   - Plan Your Visit CTA → /nextsteps
 *   - Youth (/ministries/youth) and Kids (/ministries/kids) not yet in primary nav
 */
import HarborCityIcon from './HarborCityIcon.astro';
---

<nav id="nav" aria-label="Primary">
  <a href="/" class="nav-brand" aria-label="Harbor City Church — Home">
    <HarborCityIcon size={28} />
    <span>Harbor City Church</span>
  </a>

  <ul class="nav-links">
    <li><a href="/our-story">Our Story</a></li>
    <li><a href="/your-story">Your Story</a></li>
    <li><a href="/nextsteps">Next Steps</a></li>
    <li><a href="/groups">Groups</a></li>
    <li><a href="/dreamteam">Dream Team</a></li>
    <li><a href="/give">Give</a></li>
    <li><a href="/blog">Blog</a></li>
  </ul>

  <a href="/nextsteps" class="nav-cta">Plan a Visit</a>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 24px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition:
      background 0.4s,
      padding 0.4s;
  }

  nav.scrolled {
    background: rgba(14, 27, 46, 0.95);
    padding: 16px 48px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--hcc-font-display);
    font-size: 20px;
    font-weight: 400;
    color: var(--hcc-white);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .nav-brand :global(.hcc-icon) {
    filter: brightness(0) invert(1); /* force white icon on dark nav */
    opacity: 0.95;
    transition: opacity 0.3s;
  }

  .nav-brand:hover :global(.hcc-icon) {
    opacity: 1;
  }

  .nav-links {
    display: flex;
    gap: 40px;
  }

  .nav-links a {
    font-family: var(--hcc-font-sans);
    font-size: 13px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 2px;
    transition: color 0.3s;
  }

  .nav-links a:hover {
    color: var(--hcc-gold);
  }

  .nav-cta {
    font-family: var(--hcc-font-sans);
    font-size: 12px;
    font-weight: 500;
    color: var(--hcc-gold);
    text-transform: uppercase;
    letter-spacing: 2px;
    border: 1px solid var(--hcc-gold);
    padding: 10px 28px;
    transition: all 0.3s;
  }

  .nav-cta:hover {
    background: var(--hcc-gold);
    color: var(--hcc-midnight);
  }

  @media (max-width: 768px) {
    nav {
      padding: 20px 24px;
    }
    .nav-links {
      display: none;
    }
    .nav-brand span {
      font-size: 16px;
      letter-spacing: 1.5px;
    }
  }
</style>

<script>
  // Sticky nav scroll behavior — ported from HTML
  const navEl = document.getElementById('nav');
  if (navEl) {
    const handleScroll = () => {
      navEl.classList.toggle('scrolled', window.scrollY > 80);
    };
    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll(); // run once on load in case page reloads mid-scroll
  }
</script>
