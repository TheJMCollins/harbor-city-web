---
import SectionLabel from '../global/SectionLabel.astro';

/**
 * Plan-a-visit CTA section. "Plan a Visit" is retired as a page in the
 * v2.0 sitemap; /nextsteps is the visitor pipeline. This CTA keeps the
 * eyebrow as "Plan a Visit" for emotional continuity but routes to Next Steps.
 */
---

<section id="visit" class="visit-cta">
  <div class="reveal">
    <SectionLabel>Plan a Visit</SectionLabel>
    <h2 class="section-title">We can't wait to meet you.</h2>
    <p class="section-body">
      Whether it's your first time in a church or your thousandth, you're welcome
      here. Come as you are. We saved you a seat.
    </p>
    <a href="/nextsteps" class="visit-btn">Plan Your Visit</a>
  </div>
</section>

<style>
  .visit-cta {
    background: var(--hcc-midnight);
    text-align: center;
    padding: 120px 48px;
  }

  .section-title {
    font-family: var(--hcc-font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 300;
    line-height: 1.15;
    color: var(--hcc-white);
    max-width: 600px;
    margin: 0 auto 24px;
  }

  .section-body {
    font-family: var(--hcc-font-sans);
    font-size: 17px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.8;
    max-width: 560px;
    margin: 0 auto 48px;
  }

  .visit-btn {
    display: inline-block;
    font-family: var(--hcc-font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--hcc-midnight);
    background: var(--hcc-gold);
    padding: 18px 56px;
    transition: all 0.4s;
  }

  .visit-btn:hover {
    background: var(--hcc-gold-light);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .visit-cta {
      padding: 80px 24px;
    }
  }
</style>
