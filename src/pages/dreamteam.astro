---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Dream Team"
  description="Serve with the Harbor City Church Dream Team. Use your gifts to make a difference."
>

  <section class="mp-hero">
    <div class="mp-hero__inner reveal">
      <p class="mp-eyebrow">Harbor City Church &mdash;</p>
      <h1 class="mp-headline">Your dream will fit here.</h1>
      <p class="mp-sub">Serving on a team isn&rsquo;t an obligation &mdash; it&rsquo;s where what you love meets what God is building.</p>
    </div>
  </section>

  <section class="mp-body">
    <div class="mp-inner reveal">
      <p class="mp-text">
        Everyone has a role on the team. The Dream Team is made up of ordinary
        people using their God-given gifts to make Sunday happen &mdash; and to
        care for this city far beyond Sunday morning.
      </p>
      <p class="mp-coming">Full content coming soon.</p>
      <a href="/" class="mp-home">&larr; Return home</a>
    </div>
  </section>

</BaseLayout>

<style>
  .mp-hero {
    background: var(--hcc-midnight);
    padding: 200px 48px 120px;
    text-align: center;
  }

  .mp-hero__inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .mp-eyebrow {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--hcc-gold);
    margin-bottom: 32px;
  }

  .mp-headline {
    font-family: var(--hcc-font-display);
    font-size: clamp(40px, 8vw, 96px);
    font-weight: 300;
    line-height: var(--leading-tight);
    color: var(--hcc-white);
    margin-bottom: 32px;
  }

  .mp-sub {
    font-family: var(--hcc-font-display);
    font-style: italic;
    font-size: clamp(18px, 2.5vw, 26px);
    font-weight: 300;
    line-height: var(--leading-snug);
    color: rgba(255, 255, 255, 0.5);
    max-width: 560px;
    margin: 0 auto;
  }

  .mp-body {
    background: var(--hcc-cream);
    padding: 96px 48px;
    text-align: center;
  }

  .mp-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .mp-text {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-loose);
    color: var(--hcc-text-light);
    margin-bottom: 40px;
  }

  .mp-coming {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hcc-gold);
    margin-bottom: 32px;
  }

  .mp-home {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--hcc-midnight);
    border-bottom: 1px solid rgba(14, 27, 46, 0.2);
    padding-bottom: 2px;
    transition: border-color var(--duration-base);
  }

  .mp-home:hover {
    border-color: var(--hcc-midnight);
  }

  @media (max-width: 768px) {
    .mp-hero {
      padding: 160px 24px 96px;
    }
    .mp-body {
      padding: 72px 24px;
    }
  }
</style>
