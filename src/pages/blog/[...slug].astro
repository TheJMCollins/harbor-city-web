---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, author, tags } = post.data;

const tag = tags[0] ?? 'Reflection';
const formattedDate = pubDate.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<BaseLayout
  title={title}
  description={description}
  brand="main"
>
  <fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={pubDate.toISOString()} />
    <meta property="article:author" content={author} />
  </fragment>

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="bp-hero">
    <div class="bp-hero__inner reveal">
      <p class="bp-eyebrow">{tag}</p>
      <h1 class="bp-headline">{title}</h1>
      <div class="bp-meta">
        <span class="bp-author">{author}</span>
        <span class="bp-dot" aria-hidden="true">&middot;</span>
        <time class="bp-date" datetime={pubDate.toISOString()}>{formattedDate}</time>
      </div>
    </div>
  </section>

  <!-- ── ARTICLE BODY ──────────────────────────────────── -->
  <article class="bp-article">
    <div class="bp-prose-wrap">
      <div class="bp-prose reveal">
        <Content />
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="bp-tags reveal">
          {tags.map((t) => (
            <span class="bp-tag">{t}</span>
          ))}
        </div>
      )}

      <!-- Back link -->
      <div class="bp-back reveal">
        <a href="/blog" class="bp-back__link">&larr; Back to the blog</a>
      </div>
    </div>
  </article>

  <!-- ── CLOSE ─────────────────────────────────────────── -->
  <section class="bp-close">
    <div class="bp-close__inner reveal">
      <p class="bp-close__eyebrow">Harbor City Church &mdash;</p>
      <h2 class="bp-close__headline">Come hear the rest in person.</h2>
      <a href="/nextsteps" class="bp-close__cta">Plan your visit</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── Hero ─── */
  .bp-hero {
    background: var(--hcc-midnight);
    padding: 200px 48px 100px;
    text-align: center;
  }

  .bp-hero__inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .bp-eyebrow {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--hcc-gold);
    margin-bottom: 32px;
  }

  .bp-headline {
    font-family: var(--hcc-font-display);
    font-size: clamp(36px, 7vw, 80px);
    font-weight: 300;
    line-height: var(--leading-tight);
    color: var(--hcc-white);
    margin-bottom: 40px;
  }

  .bp-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .bp-author,
  .bp-date {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.4);
  }

  .bp-dot {
    color: rgba(255, 255, 255, 0.2);
    font-size: var(--text-xs);
  }

  /* ─── Article ─── */
  .bp-article {
    background: var(--hcc-cream);
    padding: 96px 48px 120px;
  }

  .bp-prose-wrap {
    max-width: 680px;
    margin: 0 auto;
  }

  /* ─── Prose typography ─── */
  .bp-prose :global(p) {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-loose);
    color: var(--hcc-text-light);
    margin-bottom: 28px;
  }

  .bp-prose :global(h2) {
    font-family: var(--hcc-font-display);
    font-size: clamp(26px, 4vw, 40px);
    font-weight: 300;
    color: var(--hcc-midnight);
    line-height: var(--leading-snug);
    margin: 64px 0 24px;
  }

  .bp-prose :global(h3) {
    font-family: var(--hcc-font-display);
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 300;
    color: var(--hcc-midnight);
    line-height: var(--leading-snug);
    margin: 48px 0 16px;
  }

  .bp-prose :global(blockquote) {
    border-left: 2px solid var(--hcc-gold);
    padding: 8px 0 8px 32px;
    margin: 48px 0;
  }

  .bp-prose :global(blockquote p) {
    font-family: var(--hcc-font-display);
    font-style: italic;
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 300;
    color: var(--hcc-midnight);
    line-height: var(--leading-snug);
    margin-bottom: 0;
  }

  .bp-prose :global(strong) {
    font-weight: 500;
    color: var(--hcc-midnight);
  }

  .bp-prose :global(em) {
    font-style: italic;
  }

  .bp-prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(200, 169, 110, 0.4);
    margin: 56px 0;
  }

  .bp-prose :global(ul) {
    list-style: none;
    margin-bottom: 28px;
  }

  .bp-prose :global(ul li) {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-loose);
    color: var(--hcc-text-light);
    padding-left: 20px;
    position: relative;
    margin-bottom: 8px;
  }

  .bp-prose :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    width: 6px;
    height: 1px;
    background: var(--hcc-gold);
  }

  .bp-prose :global(ol) {
    padding-left: 24px;
    margin-bottom: 28px;
  }

  .bp-prose :global(ol li) {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-loose);
    color: var(--hcc-text-light);
    margin-bottom: 8px;
    padding-left: 8px;
  }

  .bp-prose :global(a) {
    color: var(--hcc-gold);
    border-bottom: 1px solid rgba(200, 169, 110, 0.35);
    transition: border-color var(--duration-base);
  }

  .bp-prose :global(a:hover) {
    border-color: var(--hcc-gold);
  }

  /* ─── Tags ─── */
  .bp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid rgba(14, 27, 46, 0.08);
  }

  .bp-tag {
    font-family: var(--hcc-font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hcc-warm-gray);
    background: rgba(14, 27, 46, 0.05);
    padding: 6px 14px;
  }

  /* ─── Back link ─── */
  .bp-back {
    margin-top: 48px;
  }

  .bp-back__link {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--hcc-midnight);
    border-bottom: 1px solid rgba(14, 27, 46, 0.2);
    padding-bottom: 2px;
    transition: color var(--duration-base), border-color var(--duration-base);
  }

  .bp-back__link:hover {
    color: var(--hcc-gold);
    border-color: var(--hcc-gold);
  }

  /* ─── Close ─── */
  .bp-close {
    background: var(--hcc-midnight);
    padding: 120px 48px;
    text-align: center;
  }

  .bp-close__inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .bp-close__eyebrow {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 24px;
  }

  .bp-close__headline {
    font-family: var(--hcc-font-display);
    font-size: clamp(28px, 4.5vw, 52px);
    font-weight: 300;
    line-height: var(--leading-snug);
    color: var(--hcc-white);
    margin-bottom: 40px;
  }

  .bp-close__cta {
    display: inline-block;
    font-family: var(--hcc-font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hcc-midnight);
    background: var(--hcc-gold);
    padding: 14px 40px;
    transition: opacity var(--duration-base) var(--ease-out);
  }

  .bp-close__cta:hover {
    opacity: 0.85;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .bp-hero {
      padding: 160px 24px 80px;
    }
    .bp-article {
      padding: 72px 24px 96px;
    }
    .bp-close {
      padding: 80px 24px;
    }
  }
</style>
