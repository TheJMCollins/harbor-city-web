---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="NextGen Youth"
  description="Harbor City Church NextGen — where middle and high school students encounter Jesus for themselves."
>

  <section class="mp-hero">
    <div class="mp-hero__inner reveal">
      <p class="mp-eyebrow">Harbor City Church &mdash;</p>
      <h1 class="mp-headline">NextGen Youth</h1>
    </div>
  </section>

  <section class="mp-body">
    <div class="mp-inner reveal">
      <p class="mp-text">
        Harbor City NextGen is where middle and high school students encounter
        Jesus for themselves &mdash; not through someone else&rsquo;s faith,
        but their own. Real community, real questions, real answers.
      </p>
      <p class="mp-coming">Full content coming soon.</p>
      <a href="/" class="mp-home">&larr; Return home</a>
    </div>
  </section>

</BaseLayout>

<style>
  .mp-hero {
    background: var(--hcc-midnight);
    padding: 200px 48px 120px;
    text-align: center;
  }

  .mp-hero__inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .mp-eyebrow {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--hcc-gold);
    margin-bottom: 32px;
  }

  .mp-headline {
    font-family: var(--hcc-font-display);
    font-size: clamp(56px, 12vw, 144px);
    font-weight: 300;
    line-height: var(--leading-tight);
    color: var(--hcc-white);
  }

  .mp-body {
    background: var(--hcc-cream);
    padding: 96px 48px;
    text-align: center;
  }

  .mp-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .mp-text {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-loose);
    color: var(--hcc-text-light);
    margin-bottom: 40px;
  }

  .mp-coming {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hcc-gold);
    margin-bottom: 32px;
  }

  .mp-home {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--hcc-midnight);
    border-bottom: 1px solid rgba(14, 27, 46, 0.2);
    padding-bottom: 2px;
    transition: border-color var(--duration-base);
  }

  .mp-home:hover {
    border-color: var(--hcc-midnight);
  }

  @media (max-width: 768px) {
    .mp-hero {
      padding: 160px 24px 96px;
    }
    .mp-body {
      padding: 72px 24px;
    }
  }
</style>
