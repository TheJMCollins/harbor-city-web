---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Our Story"
  description="Twenty-five years of showing up for Baltimore, one family at a time. The story of Harbor City Church."
  brand="main"
>

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="os-hero">
    <div class="os-hero__inner reveal">
      <p class="os-eyebrow">Our Story &mdash;</p>
      <h1 class="os-headline">
        Built on faith.<br />Rooted in community.
      </h1>
      <p class="os-sub">
        Twenty-five years of showing up for Baltimore, one family at a&nbsp;time.
      </p>
    </div>
  </section>

  <!-- ── THE BEGINNING ─────────────────────────────── -->
  <section class="os-beginning">
    <div class="os-inner">
      <div class="os-beginning__grid reveal">
        <div class="os-beginning__text">
          <p class="os-label">The Beginning</p>
          <h2 class="os-section-title">A small gathering<br />with a big idea.</h2>
          <p class="os-section-body">
            Harbor City Church began in 2001 &mdash; a small gathering of faithful
            hearts who believed Baltimore deserved a church that would meet people
            where they actually were.
          </p>
          <p class="os-section-body">
            Founders Michael and Lisa Collins had spent years preparing for this.
            Michael trained at Rhema Bible Training College under Kenneth E. Hagin.
            He worked alongside John Osteen at Lakewood Church. He and Lisa carried
            decades of ministry experience from Texas to the Baltimore region with
            one question guiding them: what would a church look like that actually
            helps people know God, find freedom, discover their purpose, and make
            a difference?
          </p>
          <p class="os-section-body">
            The answer has been unfolding ever since.
          </p>
        </div>
        <div class="os-beginning__image-area" aria-hidden="true">
          <!--
            Photo placeholder — founding-era photograph or
            current aerial/exterior. 800×1000px recommended.
          -->
          <div class="os-photo-placeholder"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PULL QUOTE ────────────────────────────────── -->
  <section class="os-pullquote">
    <div class="os-inner">
      <blockquote class="os-blockquote reveal">
        <p>We came to Baltimore to build a city of faith.</p>
      </blockquote>
    </div>
  </section>

  <!-- ── WHAT WE BELIEVE ──────────────────────────── -->
  <section class="os-believe">
    <div class="os-inner">
      <div class="os-believe__inner reveal">
        <p class="os-label os-label--invert">Our Foundation</p>
        <h2 class="os-believe__title">What we believe.</h2>
        <ul class="os-believe__list">
          <li>We believe The Bible is the living Word of God.</li>
          <li>
            We believe Jesus is who He said He was &mdash; God in flesh,
            crucified, risen, returning.
          </li>
          <li>
            We believe The Holy Spirit is present and active, and that He still
            speaks, still heals, still transforms.
          </li>
          <li>
            We believe every person &mdash; every age, every background, every
            story &mdash; can find a home In Christ.
          </li>
          <li>
            And we believe Baltimore is worth preparing for the return of Jesus
            Christ.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ── THE LONG WALK ─────────────────────────────── -->
  <section class="os-longwalk">
    <div class="os-inner">
      <div class="os-longwalk__inner reveal">
        <p class="os-label">How We Grow</p>
        <h2 class="os-section-title">A long walk,<br />not a short program.</h2>
        <p class="os-section-body">
          We don&rsquo;t believe in shortcut spirituality. We don&rsquo;t sell
          seven tips or promise instant transformation. Real change takes time
          &mdash; hearing The Word, speaking The Word, doing The Word, over and
          over, year after year, in the rhythm of your actual life.
        </p>
        <p class="os-section-body">
          Because life has rhythm. Single, married, raising kids, empty nesting,
          retired &mdash; every season has its own pace, and every season is a
          legitimate place to grow. We meet people wherever they are and we walk
          alongside them. Some of us are brand new to faith. Some have been
          following Jesus for forty years. Both are welcome. Both are growing.
          The Word keeps working, and we keep growing.
        </p>
        <p class="os-section-body">
          Harbor City is a good place to begin your walk with God. It&rsquo;s
          also a good place to go deeper and further than you&rsquo;ve ever
          gone before.
        </p>
      </div>
    </div>
  </section>

  <!-- ── PASTOR MICHAEL & LISA ─────────────────────── -->
  <section class="os-founders">
    <div class="os-inner">
      <div class="os-founders__grid reveal">
        <div class="os-founders__image-area" aria-hidden="true">
          <!--
            Photo placeholder — Michael and Lisa Collins.
            800×1000px recommended.
          -->
          <div class="os-photo-placeholder"></div>
        </div>
        <div class="os-founders__text">
          <p class="os-label">The Founders &mdash;</p>
          <h2 class="os-founders__name">Pastor Michael<br />&amp; Lisa Collins.</h2>
          <p class="os-section-body">
            Michael and Lisa have been pastoring in the Baltimore area for over
            twenty-five years. Michael trained under Kenneth E. Hagin at Rhema
            Bible Training College, served in ministry alongside John Osteen at
            Lakewood, and maintains a personal relationship with Joel Osteen
            today. Lisa &mdash; known around the church as &ldquo;GmaGirl&rdquo;
            &mdash; has been his partner in ministry from the beginning, and the
            warmth of her presence is part of why Harbor City feels like home to
            so many.
          </p>
          <p class="os-section-body">
            Together they&rsquo;ve raised four children, walked countless
            families through the hardest and holiest seasons of life, and kept
            showing up for Baltimore &mdash; one Sunday at a time.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WHERE WE'RE GOING ──────────────────────────── -->
  <section class="os-going">
    <div class="os-going__inner reveal">
      <h2 class="os-going__headline">We&rsquo;re just getting started.</h2>
      <p class="os-going__body">
        Twenty-five years in and the vision hasn&rsquo;t shrunk &mdash;
        it&rsquo;s grown. We believe God is building something real in
        Baltimore. We&rsquo;re here for the long walk. We&rsquo;re here for
        the next twenty-five years. We&rsquo;re here for you.
      </p>
      <a href="/nextsteps" class="os-going__cta">Plan your visit</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── Layout ─── */
  .os-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 48px;
  }

  /* ─── Shared label ─── */
  .os-label {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--hcc-gold);
    margin-bottom: 20px;
  }

  .os-label--invert {
    color: rgba(255, 255, 255, 0.4);
  }

  .os-section-title {
    font-family: var(--hcc-font-display);
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 300;
    line-height: var(--leading-snug);
    color: var(--hcc-midnight);
    margin-bottom: 28px;
  }

  .os-section-body {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-loose);
    color: var(--hcc-text-light);
    margin-bottom: 20px;
    max-width: 560px;
  }

  /* ─── Hero ─── */
  .os-hero {
    background: var(--hcc-midnight);
    padding: 200px 48px 160px;
    text-align: center;
  }

  .os-hero__inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .os-eyebrow {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--hcc-gold);
    margin-bottom: 32px;
  }

  .os-headline {
    font-family: var(--hcc-font-display);
    font-size: clamp(44px, 8vw, 96px);
    font-weight: 300;
    line-height: var(--leading-tight);
    color: var(--hcc-white);
    margin-bottom: 40px;
  }

  .os-sub {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-lg);
    font-weight: 300;
    line-height: var(--leading-loose);
    color: rgba(255, 255, 255, 0.5);
    max-width: 560px;
    margin: 0 auto;
  }

  /* ─── The Beginning ─── */
  .os-beginning {
    background: var(--hcc-cream);
    padding: 120px 0;
  }

  .os-beginning__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .os-photo-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    background-color: var(--hcc-warm-gray);
    background-size: cover;
    background-position: center;
  }
  .os-beginning__image-area .os-photo-placeholder {
    background-image: url('/images/our-story/beginning.jpg');
  }
  .os-founders__image-area .os-photo-placeholder {
    background-image: url('/images/our-story/founders.webp');
  }

  /* ─── Pull Quote ─── */
  .os-pullquote {
    background: var(--hcc-cream);
    padding: 80px 0;
    border-top: 1px solid rgba(14, 27, 46, 0.08);
    border-bottom: 1px solid rgba(14, 27, 46, 0.08);
  }

  .os-blockquote {
    text-align: center;
  }

  .os-blockquote p {
    font-family: var(--hcc-font-display);
    font-style: italic;
    font-size: clamp(26px, 4vw, 48px);
    font-weight: 300;
    line-height: var(--leading-snug);
    color: var(--hcc-midnight);
  }

  /* ─── What We Believe ─── */
  .os-believe {
    background: var(--hcc-midnight);
    padding: 120px 0;
  }

  .os-believe__inner {
    max-width: 760px;
  }

  .os-believe__title {
    font-family: var(--hcc-font-display);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 300;
    line-height: var(--leading-snug);
    color: var(--hcc-white);
    margin-bottom: 48px;
  }

  .os-believe__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .os-believe__list li {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-loose);
    color: rgba(255, 255, 255, 0.6);
    padding-left: 24px;
    position: relative;
  }

  .os-believe__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    width: 6px;
    height: 1px;
    background: var(--hcc-gold);
  }

  /* ─── The Long Walk ─── */
  .os-longwalk {
    background: var(--hcc-cream);
    padding: 120px 0;
  }

  .os-longwalk__inner {
    max-width: 680px;
  }

  /* ─── Founders ─── */
  .os-founders {
    background: var(--hcc-white);
    padding: 120px 0;
  }

  .os-founders__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .os-founders__name {
    font-family: var(--hcc-font-display);
    font-size: clamp(32px, 4.5vw, 56px);
    font-weight: 300;
    line-height: var(--leading-tight);
    color: var(--hcc-midnight);
    margin-bottom: 32px;
  }

  /* ─── Where We're Going ─── */
  .os-going {
    background: var(--hcc-midnight);
    padding: 120px 48px;
    text-align: center;
  }

  .os-going__inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .os-going__headline {
    font-family: var(--hcc-font-display);
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 300;
    line-height: var(--leading-tight);
    color: var(--hcc-white);
    margin-bottom: 32px;
  }

  .os-going__body {
    font-family: var(--hcc-font-sans);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-loose);
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 48px;
  }

  .os-going__cta {
    display: inline-block;
    font-family: var(--hcc-font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hcc-midnight);
    background: var(--hcc-gold);
    padding: 16px 48px;
    transition: opacity var(--duration-base) var(--ease-out);
  }

  .os-going__cta:hover {
    opacity: 0.85;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .os-hero {
      padding: 160px 24px 120px;
    }
    .os-inner {
      padding: 0 24px;
    }
    .os-beginning,
    .os-longwalk,
    .os-founders {
      padding: 80px 0;
    }
    .os-beginning__grid,
    .os-founders__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .os-founders__image-area {
      order: -1;
    }
    .os-believe {
      padding: 80px 0;
    }
    .os-pullquote {
      padding: 56px 0;
    }
    .os-going {
      padding: 80px 24px;
    }
  }
</style>
